---
import { getCollection, getEntries, render } from "astro:content";

import Tabs from "../components/detail/tabs.astro";
import Subnav from "../components/subnav.astro";
import Shell from "../layouts/shell.astro";
import Typography from "../layouts/typography.astro";
import * as Utils from "../utils";

export const getStaticPaths = async () => {
  const blogEntries = await getCollection("days");

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content: Intro } = await render(entry);

const [ballPost, winePost] = await getEntries([
  entry.data.ballContent,
  entry.data.wineContent,
]);

const [{ Content: BallContent }, { Content: WineContent }] = await Promise.all(
  [ballPost, winePost].map((ent) => render(ent)),
);

const { wine } = winePost.data;
const dateFmt = Utils.formatYYYYMMDD(entry.id);
const description = `Post for the games on ${dateFmt}${wine ? `, with a bottle of ${wine}` : ""}`;
---

<Shell description={description} title={dateFmt}>
  <div class="min-h-full bg-rose-950 p-16">
    <Subnav pageVariant="dark" />
    <main class="mt-12 md:mt-20">
      <article class="space-y-8">
        <h1
          class="text-center font-mono text-4xl text-yellow-100 sm:text-6xl md:text-8xl"
        >
          <time datetime={entry.id}>{dateFmt}</time>
        </h1>
        <section class="-mx-16 bg-yellow-50 p-8">
          <Typography class="text-rose-950">
            <Intro />
          </Typography>
        </section>
        <Tabs>
          <BallContent slot="ball" />
          <WineContent slot="wine" />
        </Tabs>
      </article>
    </main>
  </div>
</Shell>
