---
import CellarShell from "../../../layouts/cellar-shell.astro";
import Typography from "../../../layouts/typography.astro";
import wineData from "../stub";

export const getStaticPaths = () => {
  return wineData.map((wine) => {
    return {
      params: { id: wine.id },
      props: { wine },
    };
  });
};

const { wine } = Astro.props;

// Sort vintages by year (newest first)
wine.vintages.sort((a, b) => b.vintage.localeCompare(a.vintage));

const hasMultipleVintages = wine.vintages.length > 1;
---

<CellarShell
  description={`Details about ${wine.name} wine from ${wine.producer}`}
  title={`${wine.name} - Wine Detail - The Cellar`}
>
  <main class="mx-auto p-8 md:container md:p-16">
    <!-- Breadcrumb navigation -->
    <div class="mx-auto max-w-2/3">
      <nav class="font-title mx-auto mb-8 flex items-center">
        <a
          class="text-lg text-orange-600 underline decoration-wavy underline-offset-2 hover:text-orange-300"
          href="/cellar"
        >
          The Cellar
        </a>
        <span class="mx-2 text-zinc-300">&gt;</span>
        <a
          class="text-lg text-orange-600 underline decoration-wavy underline-offset-2 hover:text-orange-300"
          href="/cellar/wines"
        >
          Wines
        </a>
        <span class="mx-2 text-zinc-300">&gt;</span>
        <span class="text-lg text-zinc-300">{wine.name}</span>
      </nav>

      <div class="mb-12 md:mb-16">
        <h1 class="font-title text-center text-5xl text-amber-200 md:text-7xl">
          {wine.name}
        </h1>
        <p
          class="mt-4 text-center font-sans text-lg text-amber-200 italic md:text-xl"
        >
          {wine.producer} • {wine.vintages.length}
          {wine.vintages.length === 1 ? "vintage" : "vintages"} tried
        </p>
      </div>

      <div class="mx-auto max-w-3xl rounded-lg bg-yellow-50 p-8 shadow-lg">
        <Typography>
          {
            wine.vintages.length === 0 ? (
              <p class="text-center italic">
                No vintage information available.
              </p>
            ) : (
              <>
                {hasMultipleVintages && (
                  <div class="mb-8">
                    <h2 class="text-center text-2xl font-bold">
                      Available Vintages
                    </h2>
                    <div class="mt-4 flex flex-wrap justify-center gap-4">
                      {wine.vintages.map((vintage) => (
                        <button class="font-title rounded-full bg-purple-900 px-6 py-2 text-xl text-amber-200 hover:bg-purple-800">
                          {vintage.vintage}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

                <div>
                  <h2 class="text-center text-2xl font-bold">
                    {wine.vintages[0].vintage} Vintage
                  </h2>
                  <div class="mt-6">
                    <p>
                      <strong>Grape Varieties:</strong>{" "}
                      {wine.vintages[0].grapeVariety}
                    </p>
                    <p>
                      <strong>Date Tried:</strong>{" "}
                      {new Date(wine.vintages[0].dateTried).toLocaleDateString(
                        "en-US",
                        {
                          day: "numeric",
                          month: "long",
                          year: "numeric",
                        },
                      )}
                    </p>
                    <div class="mt-4">
                      <h3 class="text-xl font-bold">Tasting Notes</h3>
                      <p class="mt-2 italic">{wine.vintages[0].tastingNotes}</p>
                    </div>
                    <p class="mt-6 text-sm text-gray-500">
                      Future enhancements to this page will include:
                    </p>
                    <ul class="text-sm text-gray-500">
                      <li>Bottle image</li>
                      <li>Detailed producer information</li>
                      <li>Region information</li>
                      <li>Food pairing suggestions</li>
                    </ul>
                  </div>
                </div>
              </>
            )
          }
        </Typography>
      </div>
    </div>
  </main>
</CellarShell>
