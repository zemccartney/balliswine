---
import CellarShell from "../../../layouts/cellar-shell.astro";
import wineData from "../stub.ts";

// Sort wines by most recent vintage tried
wineData.sort((a, b) => a.name.localeCompare(b.name));

const fillSm = 2 - (wineData.length % 2);
const fillLg = 3 - (wineData.length % 3);
const fillXl = 4 - (wineData.length % 4);
---

<style>
  .cork {
    background-image: url(./filter.svg);
  }
</style>

<CellarShell
  description="Explore wines tried throughout the Ball is Wine blog"
  title="Wines in the Cellar"
>
  <main class="mx-auto p-8 md:container md:p-16">
    <div class="mx-auto max-w-2/3">
      <nav class="font-title mx-auto mb-8 flex items-center">
        <a
          class="text-lg text-orange-600 underline decoration-wavy underline-offset-2 hover:text-orange-300"
          href="/cellar"
        >
          The Cellar
        </a>
        <span class="mx-2 text-zinc-300">&gt;</span>
      </nav>

      <h1
        class="font-title mb-12 text-center text-5xl text-zinc-300 md:mb-16 md:text-7xl"
      >
        Wines
      </h1>
    </div>

    <div
      class="mx-auto grid w-fit grid-cols-1 gap-5 border-20 border-amber-700 border-y-amber-800/65 bg-amber-700 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    >
      {
        wineData.map((wine) => (
          <div class="relative bg-amber-950/40 backdrop-brightness-10">
            <div class="absolute top-1/10 left-1/10 z-10 w-4/5 border-2 border-emerald-600 bg-neutral-100 shadow-lg shadow-neutral-900">
              <div class="backdrop-sepia">
                {" "}
                <h3 class="font-old-style text-center text-xl text-rose-950 underline hover:text-rose-600 md:text-2xl">
                  <a href={`/cellar/wines/${wine.id}`}>{wine.name}</a>
                </h3>
                <p class="mt-4 text-center text-base text-slate-800 italic md:text-lg">
                  {wine.producer}
                </p>
              </div>
            </div>
            <div
              class:list={[
                "mx-auto h-[250px] w-[250px] rounded-full",
                wine.hue,
              ]}
            >
              <div class="cork relative top-[85px] mx-auto h-[90px] w-[90px] rounded-full outline-8 outline-slate-200/65" />
            </div>
          </div>
        ))
      }
      <div
        class:list={[
          "hidden h-[250px] w-[250px] bg-amber-950/40 backdrop-brightness-10",
          {
            "lg:max-xl:block": fillLg >= 1,
            "sm:max-lg:block": fillSm === 1,
            "xl:block": fillXl >= 1,
          },
        ]}
      >
      </div>
      <div
        class:list={[
          "hidden h-[250px] w-[250px] bg-amber-950/40 backdrop-brightness-10",
          {
            "lg:max-xl:block": fillLg >= 2,
            "xl:block": fillXl >= 2,
          },
        ]}
      >
      </div>
      <div
        class:list={[
          "hidden h-[250px] w-[250px] bg-amber-950/40 backdrop-brightness-10",
          {
            "xl:block": fillXl === 3,
          },
        ]}
      >
      </div>
    </div>
  </main>
</CellarShell>
